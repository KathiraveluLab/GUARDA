# GUARDA Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!

# === Required for Production ===

# Database URL for the main GUARDA Ecto Repo (Phoenix default)
DATABASE_URL=ecto://USER:PASS@localhost/guarda_prod

# Secret key base for signing cookies/sessions. Generate with: mix phx.gen.secret
SECRET_KEY_BASE=

# Hostname for the production server
PHX_HOST=guarda.example.com

# === Optional ===

# Server port (default: 4000)
PORT=4000

# Enable the Phoenix server (required for releases)
PHX_SERVER=true

# DNS cluster query for distributed Erlang (leave empty for single-node)
DNS_CLUSTER_QUERY=

# Ecto connection pool size (default: 10)
POOL_SIZE=10

# Enable IPv6 for Ecto connections (set to "true" or "1")
ECTO_IPV6=

# CORS allowed origins (comma-separated, default: http://localhost:4000)
CORS_ORIGINS=http://localhost:4000

# Max number of concurrent provider actors (default: 100)
MAX_PROVIDERS=100
